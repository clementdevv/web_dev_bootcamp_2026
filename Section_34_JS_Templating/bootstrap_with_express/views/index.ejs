<!DOCTYPE html>
<html lang="en">
<head>
    <title>Bootstrap + Express</title>

    <!-- Bootstrap CDN -->
    <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">

</head>

<body class="container mt-5">

    <h1 class="text-primary">
        Bootstrap + Express
    </h1>

    <p class="lead">
        This page is styled using Bootstrap inside an EJS template.
    </p>

    <button class="btn btn-success">
        Click Me
    </button>

    <div class="card mt-4" style="width: 18rem;">
        <div class="card-body">
            <h5 class="card-title">Example Card</h5>
            <p class="card-text">
                Bootstrap components work perfectly inside EJS templates.
            </p>
        </div>
    </div>

</body>
</html>