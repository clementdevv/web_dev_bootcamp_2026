
<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <style>
    body { font-family: Arial; max-width: 600px; margin: 0 auto; padding: 20px; }
    .form-group { margin-bottom: 15px; }
    label { display: block; margin-bottom: 5px; font-weight: bold; }
    input, textarea { width: 100%; padding: 8px; box-sizing: border-box; }
    button { background: #007bff; color: white; padding: 10px 20px; border: none; cursor: pointer; }
  </style>
</head>
<body>
  <h1>Edit <%= farm.name %></h1>
  
  <form action="/farms/<%= farm._id %>?_method=PUT" method="POST">
    <div class="form-group">
      <label>Farm Name</label>
      <input type="text" name="name" value="<%= farm.name %>" required>
    </div>
    
    <div class="form-group">
      <label>Location</label>
      <input type="text" name="location" value="<%= farm.location %>" required>
    </div>
    
    <div class="form-group">
      <label>Description</label>
      <textarea name="description" rows="4"><%= farm.description || '' %></textarea>
    </div>
    
    <div class="form-group">
      <label>Established Year</label>
      <input type="number" name="establishedYear" value="<%= farm.establishedYear || '' %>">
    </div>
    
    <div class="form-group">
      <label>
        <input type="checkbox" name="isOrganic" value="true" <%= farm.isOrganic ? 'checked' : '' %>>
        Organic Farm
      </label>
    </div>
    
    <button type="submit">Update Farm</button>
    <a href="/farms/<%= farm._id %>">Cancel</a>
  </form>
</body>
</html>